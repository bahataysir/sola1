# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
# Local:
MONGODB_URI=mongodb://localhost:27017/solar_hebron

# Atlas (Production):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/solar_hebron?retryWrites=true&w=majority

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Scoring Weights (optional tuning) ────────────────────
WEIGHT_SOLAR=20
WEIGHT_GRID=5
WEIGHT_AREA=2
